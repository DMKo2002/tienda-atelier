# Mismas credenciales de Supabase que el panel admin
NEXT_PUBLIC_SUPABASE_URL=https://TU_PROJECT_ID.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=TU_ANON_KEY

# tenant_id del local (cada tienda tiene el suyo)
NEXT_PUBLIC_TENANT_ID=00000000-0000-0000-0000-000000000001

# URL del panel admin (para links internos)
NEXT_PUBLIC_PANEL_URL=http://localhost:3000
